# ใช้ PORT=5000 เพื่อกำหนด port ของ server
PORT=5000

# Database connection string (DSN) for PostgreSQL
DB_DSN=postgres://postgres:password@localhost:5432/go_minimal_db?sslmode=disable

# Secret key สำหรับการเข้ารหัส JWT (JSON Web Token) ใช้สำหรับการยืนยันตัวตนของผู้ใช้
JWT_SECRET=gopher-by-taerabyte

# Comma-separated list of origins allowed to call this API from a browser (e.g. http://localhost:3000,https://myapp.com)
# ใช้ "*" เพื่ออนุญาตทุก origin (เหมาะกับตอน dev เท่านั้น ห้ามใช้ "*" คู่กับ production ที่ต้องส่ง cookie)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://myapp.com
CORS_ALLOWED_ORIGINS=*

